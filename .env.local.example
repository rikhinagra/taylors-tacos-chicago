# ══════════════════════════════════════════════════════
# TAYLOR'S TACOS CHICAGO — ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════
# Copy this file and rename it to .env.local
# Fill in the values below with your actual credentials

# ── SITE ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://taylors-tacos-chicago.vercel.app

# ── CONTACT FORM (Google Apps Script Web App URL) ──────
# Get this URL from: script.google.com → Deploy → Web App
NEXT_PUBLIC_CONTACT_FORM_URL=your_google_apps_script_web_app_url_here
